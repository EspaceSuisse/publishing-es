{% macro listMacro(queryParam, classParam) %}

	{% import '_macros/macroCatOverview' as macroCat %}

	{% set catGenre = queryParam.fCatGenre.all() %}
	{% set catSubject = queryParam.fCatSubject.all() %}

	<article class="articlePreview previewSizeS {{ classParam }}">


		<div class="tags">
			{{ macroCat.catOverview(catGenre, 'genre') }}
			{{ macroCat.catOverview(catSubject, 'subject') }}
		</div>
		<a href="{{ queryParam.url }}">
			<h2>{{ queryParam.title }}</h2>
			{% include "_components/previewPostDate.twig" %}
		</a>
	</article>

{% endmacro %}
