{% macro figCaption(assetParam, captionParam, hasSourceParam) %}
    {% import '_macros/macroFields' as macroFields %}

    <figcaption>
        {% if captionParam %}
            <div class="caption">{{ captionParam }}</div>
        {% endif %}

        {% if hasSourceParam == false %}
            {% set provider = assetParam.fTagProvider.one() %}
            {% set licence = assetParam.fImgLicence.one() %}

            <p class="assetSource">
                ({{ 'Quelle' | t }}:
                {% for block in assetParam.fmImgSource.all() %}
                    {% switch block.type %}
                        {% case "tMonolingual" %}
                            {{ block.fPlainTxt ~ ', ' }}
                        {% case "tMultilingual" %}
                            {{ macroFields.richText(block.fPlainTextI18n ~ ', ') }}
                    {% endswitch %}
                {% endfor %}
                {%- if provider -%}{{- provider -}}{%- endif -%}
                {%- if licence -%}{{- '' ~ licence -}}{%- endif -%}
                )
            </p>
        {% endif %}
    </figcaption>
{% endmacro %}