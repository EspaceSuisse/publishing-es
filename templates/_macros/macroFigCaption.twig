{% macro figCaption(assetParam, captionParam) %}
	<figcaption>
		{% if captionParam %}
			<p class="caption">{{ captionParam }}</p>
		{% endif %}
        <p class="assetSource">
                {{- assetParam.fPlainTextI18n -}}
                {%- if assetParam.fTagProvider.one() -%}{{- ', ' ~ assetParam.fTagProvider.one() }}{%- endif -%}
                {%- if assetParam.fImgLicence.one() -%}{{- '–' ~ assetParam.fImgLicence.one() }}{%- endif -%}
        </p>
	</figcaption>
{% endmacro %}
