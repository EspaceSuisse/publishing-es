{% macro articleImage(handleParam, transformKey, paramClass) %}
    {% if handleParam is null %}
        no image
    {% elseif handleParam.extension|lower == 'svg' %}
        {{ svg(handleParam) }}
    {% else %}
        {% set imagerConfig   = craft.app.config.getConfigFromFile('imager-x-transforms') %}
        {% set namedTransform = imagerConfig[transformKey] ?? null %}

        {% if namedTransform %}
            {% set deviceMap = namedTransform.transforms | map(t => t.device) %}
            {% set transformedImages = craft.imagerx.transformImage(handleParam, transformKey) %}

            {% set deviceBreakpoints = {
                mobile:  null,
                tablet:  '(min-width: 48rem)',
                desktop: '(min-width: 63rem)',
            } %}

            <picture class="{{ paramClass ?? 'imgItem' }} fadeImg">
                {% for img in transformedImages %}
                    {% set device     = deviceMap[loop.index0] ?? null %}
                    {% set mediaQuery = deviceBreakpoints[device] ?? null %}
                    <source srcset="{{ img.url }}"
                            {% if mediaQuery %}media="{{ mediaQuery }}"{% endif %}
                            data-device="{{ device }}">
                {% endfor %}
                <img src="{{ transformedImages[0].url }}"
                     alt="{{ (handleParam.fPlainTextI18nMultiline ?? '') | e('html_attr') }}"
                     title="{{ handleParam.title | e('html_attr') }}"
                     loading="lazy" decoding="async"
                     onload="this.closest('picture').classList.add('loaded')"
                     >
            </picture>
        {% endif %}
    {% endif %}
{% endmacro %}