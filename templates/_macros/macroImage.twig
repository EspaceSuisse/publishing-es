{% macro articleImage(handleParam, transformKey, paramClass, paramLazy = true) %}

    {% import '_macros/macroImageSource' as macroImageSource %}

    {% if handleParam is null %}
        no image
    {% elseif handleParam.extension|lower == 'svg' %}
        {{ svg(handleParam) }}
    {% else %}
        {% set imagerConfig   = craft.app.config.getConfigFromFile('imager-x-transforms') %}
        {% set namedTransform = imagerConfig[transformKey] ?? null %}

        {% if namedTransform %}
            {% set deviceBreakpoints = {
                mobile:  null,
                tablet:  '(min-width: 48rem)',
                desktop: '(min-width: 63rem)',
            } %}

            {# largest viewport first, so the first matching <source> wins #}
            {% set ordered = namedTransform.transforms | sort((a, b) =>
                (deviceBreakpoints[b.device] is not null) <=> (deviceBreakpoints[a.device] is not null)
            ) %}

            {% set fallback = craft.imagerx.transformImage(handleParam, [namedTransform.transforms[0]])[0] %}

            <picture class="{{ paramClass ?? 'imgItem' }} fadeImg">
                {% for transform in namedTransform.transforms %}
                    {% set img        = craft.imagerx.transformImage(handleParam, [transform])[0] %}
                    {% set device     = transform.device ?? null %}
                    {% set mediaQuery = deviceBreakpoints[device] ?? null %}
                    <source srcset="{{ img.url }}"
                            {% if mediaQuery %}media="{{ mediaQuery }}"{% endif %}
                            width="{{ img.width }}" height="{{ img.height }}"
                            data-device="{{ device }}">
                {% endfor %}
                <img src="{{ fallback.url }}"
                     width="{{ fallback.width }}"
                     height="{{ fallback.height }}"
                     alt="{{ (handleParam.fPlainTextI18nMultiline ?? '') | e('html_attr') }}"
                     title="{{ (handleParam.title|trim ~ ' ' ~ macroImageSource.imageSource(handleParam)|trim)|e('html_attr') }}"
                     {% if paramLazy %}loading="lazy"{% else %}loading="eager" fetchpriority="high"{% endif %}
                     decoding="async"
                     onload="this.closest('picture').classList.add('loaded')">
            </picture>
        {% endif %}
    {% endif %}
{% endmacro %}