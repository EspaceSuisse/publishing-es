{# This macro is used to print out the category overview link #}
{# It takes the url params for the two languages and a class for the link #}
{# The label is taken from the translation file #}

{%- macro catOverview(catParam, classParam, linkParam) -%}
	{% for item in catParam %}

		{% set inlineStyle = item.fColor ? 'background-color:' ~ item.fColor ~ ';' : '' %}
		{% set fullTitle = item.title %}


			<span class="tag {{ ' ' ~ classParam }}"> 
            {%- if linkParam == true -%}
				<a href="{{- item.url -}}" style="{{ inlineStyle }}">
					{{- fullTitle -}}
				</a>
			{%- else -%}
				{{- fullTitle -}}
			{%- endif -%}
		</span>
	{%- endfor -%}
{%- endmacro -%}