{% macro listMacro(queryParam, classParam) %}

	{% import '_macros/macroImage' as macroImg %}
	{% import '_macros/macroCatOverview' as macroCat %}

	{% set image = queryParam.fArticleImgI18n.one() %}
	{% set catGenre = queryParam.fCatGenre.all() %}
	{% set catSubject = queryParam.fCatSubject.all() %}

	<article class="articlePreview previewSizeXL {{ classParam }}">
		<a href="{{ queryParam.url }}">
			{{ macroImg.articleImage(image, 'articleThumb', 'previewImg') }}
		</a>
		<div class="tags">
			{{ macroCat.catOverview(catGenre, 'genre', true) }}
			{{ macroCat.catOverview(catSubject, 'subject', true) }}
		</div>

		<div class="txtPart">
			<h2>
				<a href="{{ queryParam.url }}">{{ queryParam.title }}</a>
			</h2>
			<p class="lead">{{ queryParam.fSeoDescription}}</p>
			{% include "_components/previewPostDate.twig" %}
		</div>

	</article>

{% endmacro %}
