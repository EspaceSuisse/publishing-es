{%- macro dropdown(paramQuery, paramLabel) -%}

	{% import '_components/previewCards/macroArticlePreview' as macroArticlePreview %}

	<li class="hasDropdown navToplevelLink">
		<button class="dropdownLink" aria-haspopup="true" aria-expanded="false" aria-controls="dropdown-menu-{{ paramLabel | ascii }}">
			<span class="buttonTxt">{{ paramLabel | t }}</span>
		</button>
		<div class="dropdown" id="dropdown-menu-{{ paramLabel | ascii }}" role="menu">
			
				{% for category in paramQuery %}
				<ul>
					{% set relatedArticle = craft.entries()
						.section('article')
						.relatedTo(category)
						.limit(3)
						.all() 
					%}

					<li class="relatedNav">
						<h2 class="subnavCatTitle"><a href="{{ category.url }}">{{ category.title }}</a></h2>
						<ul class="subnavCatArticles">
							{% for item in relatedArticle %}
								<li class="catArticle">
									<a href="{{ item.url }}">
										<h3 class="catArticleTitle">{{ item.title }}</h3>
										<p class="catArticleDescription">{{ item.fSeoDescription }}</p>
									</a>
								</li>
							{% endfor %}
						</ul>
					</li>
					</ul>
				{% endfor %}
			
		</div>
	</li>
{%- endmacro -%}
