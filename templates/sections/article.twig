{% extends "_layouts/main" %}

{# Eager Load this stuff which is possible #}
{% do craft.app.elements.eagerLoadElements(
    className(entry),
    [entry],
    [
        'imgAufmacher',
        'imgAufmacher.fTagProvider',
        'imgAufmacher.fImgLicence',
        'imgAufmacher.fmImgSource',

        'fCatGenre',
        'fCatSubject',

        'authors',
        'authors.photo',
        'authors.fTeam',

        'fMxArticleBlocks',

        'fMxArticleBlocks.fImgI18n',
        'fMxArticleBlocks.fImgI18n.fTagProvider',
        'fMxArticleBlocks.fImgI18n.fImgLicence',
        'fMxArticleBlocks.fImgI18n.fmImgSource',

        'fMxArticleBlocks.fMxImgGallery',
        'fMxArticleBlocks.fMxImgGallery.fImgI18n',
        'fMxArticleBlocks.fMxImgGallery.fImgI18n.fTagProvider',
        'fMxArticleBlocks.fMxImgGallery.fImgI18n.fImgLicence',
        'fMxArticleBlocks.fMxImgGallery.fImgI18n.fmImgSource',

        'fMxArticleBlocks.fRelEntry',
        'fMxArticleBlocks.fRelEntry.imgAufmacher',

        'fMxArticleBlocks.fFile',

        'fMxArticleBlocks.fmImgSource',
    ]
) %}

{% set aufmacherBild = entry.imgAufmacher.one() ?? null %}
{% set articleGenre = entry.fCatGenre %}
{% set articleSubject = entry.fCatSubject %}
{% set hasNoImage = aufmacherBild is null %}

{# 
This is the template for all articles.
It includes the header and the matrix include which contains a switch statement.
In the switch statement the different blocks are included.
The blocks are defined in the matrix field in the CMS.
#}

{# check if the article is older than 3 months #}
{% set articleSunset = entry.postDate|date_modify('+' ~ siteBrand.fNumber ~ ' days') %}
{% set isSunset = articleSunset < now %}
{% set daysLeft = isSunset ? 0 : now.diff(articleSunset).days %}
{% set isPreview = craft.app.request.getParam('token') is not null %}
{% set freeForAll = entry.fSwitch %}

{# Set Blitz cache to expire exactly on sunset date,
   but only if the sunset is still in the future.
   Otherwise Blitz loops forever regenerating the cache. #}
{% if articleSunset > now %}
    {# Sunset is in the future — expire exactly on sunset #}
    {% do craft.blitz.options().expiryDate(articleSunset) %}
{% else %}
    {# Already sunset — cache for a week, then natural refresh #}
    {% do craft.blitz.options().expiryDate(now|date_modify('+7 days')) %}
{% endif %}


{# Default empty class #}
{% set articleSunsetClass = '' %}

{# Check if user is logged in #}
{% set isLoggedIn = craft.app.user.identity is not null %}

{# Check if article has Image #}
{% set hasNoImage = entry.imgAufmacher.one() is null %}
{% set noImageSubjectColor = entry.fCatGenre.one() %}

{# Update based on logic - don't sunset if logged in #}
{% if not isPreview and not isLoggedIn and not freeForAll %}
    {% set articleSunsetClass = isSunset ? 'articleIsSunset' : '' %}
{% endif %}

{% block content %}

	{% include "_dynamic/devSunsetPanel" %}

	<article>		
		<header class="pageHead articleHead {{ hasNoImage ? 'noImg' : '' }}">
			{% include "_components/header/headerBrand" %}
			{% include "_components/header/headerArticle" %}
			{% if hasNoImage %}<div class="colorHead" style="background-color: {{ noImageSubjectColor.fColor ?? 'var(--colorES-brand-blue)' }};"></div>{% endif %}
		</header>
		<div class="gridArticle {{ articleSunsetClass }} articleContent">
			{% include "_components/articleMatrix" %}
		</div>
		{# {% include "_components/articleCtaCall" %} #}
		{% include "_components/articleMoreArticles" %}
	</article>
	{% include "_dynamic/lightboxInitiator" %}


{# 3. Inject the Dynamic Eraser #}
{#    Only necessary if the article IS currently sunset #}
{% if isSunset %}
    {{ craft.blitz.includeDynamic('_dynamic/unlockScript.twig') }}
{% endif %}

{% endblock %}