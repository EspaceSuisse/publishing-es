{% set latestArticles = craft.entries.section('article').site(site).limit(3).all() %}
{% set language = site.language %}

[
{% for item in latestArticles %}

    {% set articleImage = '' %}
    {% set image = item.fImgMono.one() %}
    {% if image %}
        {% set transform = craft.imagerx.transformImage(image, 'feedImageTransform') | first %}
        {% set articleImage = craft.app.sites.getSiteByHandle('default').baseUrl|trim(  '/', 'right' ) ~ transform.url %}
    {% endif %}

    {
        "title": "{{  item.fPlainTextI18n ??  item.title }}",
        "imageUrl": "{{ articleImage }}",
        "description": "{{ item.fSeoDescription }}",
        "url": "{{ item.url }}",
        "postDate": "{{ item.postDate | date('c') }}",
        "postDateUnix": {{ item.postDate | date('U') }},
        "language": "{{ language }}",
        "categories": [
            {% for category in item.fCatSubject.all() %}
                {
                    "title": "{{ category.title }}"
                }{% if not loop.last %},{% endif %}
            {% endfor %}
            ]
    }{% if not loop.last %},{% endif %}
{% endfor %}
]