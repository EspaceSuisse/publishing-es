{% js %}
	(function () {
		"use strict";

		function initColorChecker() {
			var labels = document.querySelectorAll(".tagLabel");

			labels.forEach(function (label) {
			// Walk up until we find an ancestor with a background-color
			var bg = findBackgroundColor(label);
			if (!bg) return;

			var rgb = parseRGB(bg);
			if (!rgb) return;

			var luminance = getRelativeLuminance(rgb.r, rgb.g, rgb.b);
			var contrastBlack = (luminance + 0.05) / 0.05;
			var contrastWhite = 1.05 / (luminance + 0.05);

			label.style.color =
				contrastBlack > contrastWhite ? "var(--txtColor)" : "var(--txtInvertColor)";
			});
		}

		/**
		* Walk up the DOM from the label and return the first
		* resolved background-color that isn't transparent / rgba(0,0,0,0)
		*/
		function findBackgroundColor(el) {
			var node = el.parentElement;
			while (node && node !== document.documentElement) {
			var bg = getComputedStyle(node).backgroundColor;
			if (bg && bg !== "rgba(0, 0, 0, 0)" && bg !== "transparent") {
				return bg;
			}
			node = node.parentElement;
			}
			return null;
		}

		function parseRGB(str) {
			var match = str.match(/rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/);
			if (!match) return null;
			return {
			r: parseInt(match[1]),
			g: parseInt(match[2]),
			b: parseInt(match[3]),
			};
		}

		/**
		* WCAG 2.0 relative luminance
		* L = 0.2126 R + 0.7152 G + 0.0722 B
		*/
		function getRelativeLuminance(r, g, b) {
			var sR = r / 255,
			sG = g / 255,
			sB = b / 255;

			var R =
			sR <= 0.03928 ? sR / 12.92 : Math.pow((sR + 0.055) / 1.055, 2.4);
			var G =
			sG <= 0.03928 ? sG / 12.92 : Math.pow((sG + 0.055) / 1.055, 2.4);
			var B =
			sB <= 0.03928 ? sB / 12.92 : Math.pow((sB + 0.055) / 1.055, 2.4);

			return 0.2126 * R + 0.7152 * G + 0.0722 * B;
		}

		// Run on DOM ready
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", initColorChecker);
		} else {
			initColorChecker();
		}
	})();
{% endjs %}