{# Cache-safe unlock: strips `.articleIsSunset` from `#protected-article`
   pre-paint when the `hasAccess` cookie (set by manageplus Module) is present. #}
<script>
  if (/(?:^|; )hasAccess=1/.test(document.cookie)) {
    const unlock = () => document.getElementById('protected-article')?.classList.remove('articleIsSunset');
    new MutationObserver((_, o) => document.getElementById('protected-article') && (unlock(), o.disconnect()))
      .observe(document.documentElement, { childList: true, subtree: true });
    addEventListener('DOMContentLoaded', unlock, { once: true });
    addEventListener('pageshow', e => e.persisted && unlock());
  }
</script>
