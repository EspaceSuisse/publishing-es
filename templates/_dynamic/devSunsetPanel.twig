
{% set articleSunset = entry.postDate|date_modify('+' ~ siteBrand.fNumber ~ ' days') %}
{% set isSunset = articleSunset < now %}
{% set daysLeft = isSunset ? 0 : now.diff(articleSunset).days %}
{% set articleSunsetClass = isSunset ? 'articleIsSunset' : '' %}
{% set freeForAll = entry.fSwitch %}


<code style="color: red; background-color: #fdd; position: absolute; top: 0; right: 0; z-index: 9999; padding: 5px; border: 2px solid red; font-size: 18px">
    <pre>
        Post Date: {{ entry.postDate|date("Y-m-d") }}
        Article Sunset Date: {{ articleSunset|date("Y-m-d") }}
        Is Sunset: {{ isSunset ? 'Yes' : 'No' }}
        Days Left: {{ daysLeft }}
        Free For All: {{ freeForAll ? 'Yes' : 'No' }}
    </pre>
</code>