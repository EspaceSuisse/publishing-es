

{# This is the site navigation for the header #}
{# It uses the macro to print out the category overview link #}
{# The two categories are fetched with only url and title #}


{% set navSubject = craft.categories()
    .group('catSubject')
    .relatedTo({ sourceElement: articleIds })
    .all() %}

{% set navGenre = craft.categories()
    .group('catGenre')
    .relatedTo({ sourceElement: articleIds })
    .all() %}

{% set currentPath = craft.app.request.pathInfo %}

<nav aria-label="{{ 'Navigation' | t }}" role="navigation"> 
	<ul class="siteNav">
		{% include "_components/sideBar/navInnerContent.twig" %}
	</ul>
</nav>

{% include "_components/sideBar/navJsDropdown.twig" %}
