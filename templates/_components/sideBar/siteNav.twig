{% import '_macros/macroDropdown' as dropMacro %}

{# This is the site navigation for the header #}
{# It uses the macro to print out the category overview link #}
{# The two categories are fetched with only url and title #}


{% set navSubject = craft.categories.group('catSubject')
	.with(['title','url'])
	.relatedTo({ sourceElement: craft.entries.section('article') })
	.all() %}

{% set navGenre = craft.categories.group('catGenre')
	.with(['title','url'])
	.relatedTo({ sourceElement: craft.entries.section('article') })
	.all() %}

{% set articleSearch = craft.entries.section('allArticles').with(['title','url']).one() %}

{% set currentPath = craft.app.request.pathInfo %}

<nav aria-label="{{'Main navigation'|t}}" role="navigation"> 
	<ul class="siteNav">
		{% include "_components/sideBar/homepageLink.twig" %}
		{{ dropMacro.dropdown(navSubject, labelSubject, currentPath) }}
		{{ dropMacro.dropdown(navGenre, labelGenre, currentPath) }}

		{# <li class="navIcon">
			<a href="{{ articleSearch.url }}">
				{{ articleSearch.title }}
			</a>
		</li> #}

		{% include "_components/sideBar/siteNavMoreLinks.twig" %}
		{% include "_components/sideBar/navLangSwitcher.twig" %}
	</ul>
</nav>

{% include "_components/sideBar/navJsDropdown.twig" %}
