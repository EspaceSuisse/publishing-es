<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://use.typekit.net/zfp0qhw.css">
  {% hook "seomaticRender" %}

  <link rel="stylesheet" href="/theme/css/esPublishing.css?v={{ now|date('U') }}">

  {% set currentHandle = currentSite.handle %}
  {% set secondHandle = currentHandle == 'espacesuissePublishingFr' ? 'default' : 'espacesuissePublishingFr' %}
  {% set secondSite = craft.app.sites.getSiteByHandle(secondHandle) %}

<link rel="alternate" type="application/rss+xml" title="{{ currentSite.name }} ({{ currentSite.language|slice(0,2) }})" href="{{ currentSite.baseUrl }}feeds/feed-{{ currentSite.language|slice(0,2) }}.rss">
<link rel="alternate" type="application/rss+xml" title="{{ secondSite.name }} ({{ secondSite.language|slice(0,2) }})" href="{{ secondSite.baseUrl }}feeds/feed-{{ secondSite.language|slice(0,2) }}.rss">

<link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
<link rel="shortcut icon" href="/favicon/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
<link rel="manifest" href="/favicon/site.webmanifest" />
 
</head>