{% import '_macros/macroLinkList' as listMacro %}
{% import '_macros/macroFields' as fieldsMacro %}
{% import '_macros/macroCatOverview' as macroCat %}

{% set labelSubject = 'Themen' %}
{% set labelGenre = 'Genres' %}

{% set queryFooterSubject = craft.categories.group('catSubject')
	.with(['title','url'])
	.relatedTo({ sourceElement: craft.entries.section('article') })
	.all() %}

{% set queryFooterGenre = craft.categories.group('catGenre')
	.with(['title','url'])
	.relatedTo({ sourceElement: craft.entries.section('article') })
	.all() %}

{% set querySubpages = craft.entries.section('subpages')
    .with(['title','url'])
    .all()
%}

{% set queryLatestArticle = craft.entries.section('article')
    .with(['title','url',])
    .limit('10')
    .all()
%}

{% set articleSearch = craft.entries.section('allArticles').with(['title','url']).one() %}


<footer>
	<div class="listingGrid">
		<div class="footerContact gridSpan4">
			{{ fieldsMacro.richText(footerGlobals.fRichTextI18n) }}
		</div>
		<div class="latestArticles gridSpan8">
			{{ listMacro.listMacro(queryLatestArticle, 'Das neuste' | t, null, 'entryList' ) }}
			<p class="listItem"><a href="{{ articleSearch.url }}" class="btn">{{ articleSearch.title }}</a></p>
		</div>
		<div class="footerCategories gridStart5 gridSpan8">
			{{ macroCat.catOverview(queryFooterSubject, 'subject') }}
			{{ macroCat.catOverview(queryFooterGenre, 'genre') }}
		</div>
		<div class="subPages gridSpan4">
			{{ listMacro.listMacro(querySubpages, null, null, 'entryList' ) }}
		</div>
	</div>
</footer>
