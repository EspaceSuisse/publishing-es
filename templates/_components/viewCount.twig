{% if getenv('CRAFT_ENVIRONMENT') == 'production' %}

    {% js %}
        {% if category.id is defined %}
            {% set elementId = category.id %}
        {% else %}
            {% set elementId = entry.id %}
        {% endif %}
        
        const elementId = {{ elementId }};

        const incrementViewCountUrl = '/actions/view-count/increment';

        const data = {
            id: elementId
        };

        async function incrementView() {
            try {
                const response = await fetch(incrementViewCountUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                console.log('View count updated:', result);
            } catch (err) {
                console.error('View count error:', err);
            }
        }

        incrementView();
    {% endjs %}
    
{% endif %}