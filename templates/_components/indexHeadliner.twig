{% import '_components/previewCards/macroArticlePreviewXL' as macroPreviewXL %}
{% import '_components/previewCards/macroArticlePreviewL' as macroPreviewL %}
{% import '_components/previewCards/macroArticlePreviewS' as macroPreviewS %}
{% import '_macros/macroCatOverview' as macroCat %}

{% set superTopic = entry.fSuperTopic.one() %}
{% set headliner = allEntries | first %}
{% set superTopicEntries = craft.entries.section('article').relatedTo(superTopic).limit(3).all() %}

<section class="headliner">

	{% if superTopic %}
    
        {{ macroPreviewXL.listMacro(headliner,'gridStart1 gridSpan8 headlineNews') }}
        <div class="gridSpan4 superTopic">
            <h2>{{ superTopic.title }}</h2>
            {% for item in superTopicEntries %}
                {{ macroPreviewL.listMacro(item, null) }}
            {% endfor %}
        </div>

    {% else %}

         {{ macroPreviewXL.listMacro(headliner,'gridStart1 gridSpan12') }}
        
    {% endif %}
</section>


{% js %}

    const headliner = document.querySelector(".headlineNews");
    const superTopic = document.querySelector(".superTopic");

    if (headliner && superTopic) {

    const applyHeight = () => {
        const height = headliner.offsetHeight;
        if (height > 0) {
        superTopic.style.maxHeight = `${height}px`; // limit to headline height
        superTopic.classList.add("is-ready");      // show with optional transition
        }
    };

    // Run once after images/fonts load
    window.addEventListener("load", applyHeight);

    // Optional: adjust if viewport resizes
    window.addEventListener("resize", applyHeight);
    }



{% endjs %}
