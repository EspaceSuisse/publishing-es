

{# https://maplibre.org/maplibre-gl-js/docs/ #}
{# https://api3.geo.admin.ch/services/sdiservices.html#mapbox-vector-tiles #}
{# Swisstopo Layers: https://wms.geo.admin.ch/?REQUEST=GetCapabilities&SERVICE=WMS&VERSION=1.3.0 #}

<link href="https://unpkg.com/maplibre-gl@5.7.1/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/maplibre-gl@5.7.1/dist/maplibre-gl.js"></script>


{% set mapLatitude = block.fLat ?? '46.798591' %}
{% set mapLongitude = block.fLong ?? '8.231772' %}
{% set mapZoom = block.fZoom ?? '10' %}
{% set mapLayer = block.fPlainTxt %}
{% set polygonPath = block.fCode.value ?? '' %}
{% set markerEnabled = block.fSwitch ?? false %}
{% set mapKey = block.id %}

{# add markers if they are present #}
{% set mapMarkers %}
    {% if block.fMxMarker %}

        const markers = [
            {% for item in block.fMxMarker %}
                {
                    coords: [{{ item.fLong }}, {{ item.fLat }}],
                    text: '{{ item.title }}'
                },
            {% endfor %}
        ];

        markers.forEach(m => {
            const popup = new maplibregl.Popup({ offset: 25 }).setText(m.text);
            const randomColor = "#000000".replace(/0/g,function(){return (~~(Math.random()*16)).toString(16);});
            new maplibregl.Marker({ color: randomColor})
                .setLngLat(m.coords)
                .setPopup(popup)
                .addTo(map);
        });

    {% endif %}
{% endset %}


{# set base map style #}
{%- set baseMapLayer -%}
    {%- if block.fBaseMap -%}
        {%- switch block.fBaseMap -%}
            {%- case "pixelkarte-farbe" -%}
                'https://vectortiles.geo.admin.ch/styles/ch.swisstopo.basemap.vt/style.json'
            {%- case "swissimage" -%}
                'https://vectortiles.geo.admin.ch/styles/ch.swisstopo.imagerybasemap.vt/style.json'
            {%- case "pixelkarte-grau" -%}
                'https://vectortiles.geo.admin.ch/styles/ch.swisstopo.lightbasemap.vt/style.json'
        {%- endswitch -%}
    {%- endif -%}
{%- endset -%}

{# set additional map data layer #}
{% set mapDataLayer %}
    {% if block.fPlainTxt %}
        map.on('load', () => {
            map.addSource('wms-source', {
                'type': 'raster',
                'tiles': [
                    'https://wms.geo.admin.ch/?SERVICE=WMS&VERSION=1.3.0&REQUEST=GetMap' +
                    '&FORMAT=image/png' +
                    '&TRANSPARENT=true' +
                    '&LAYERS={{ block.fPlainTxt }}' +
                    '&CRS=EPSG:3857' +
                    '&WIDTH=256&HEIGHT=256' +
                    '&BBOX={bbox-epsg-3857}'
                ],
                'tileSize': 256
            });

            map.addLayer({
                'id': 'wms-layer',
                'type': 'raster',
                'source': 'wms-source',
                'paint': {
                    'fill-color': '#888888',   // fill color
                    'fill-opacity': 0.5        // transparency
                }
            });
        });
    {% endif %}
{% endset %}

{# set polygon lines #}
{# THis generates the polygon or circle lines drawn on the map in polyigon matrix fields #}
{% set polygonLines %}
    map.on('load', () => {
        {% for item in block.fPolygons %}
            // Unique source id
            map.addSource('polygon-source-{{ loop.index }}', {
                'type': 'geojson',
                'data': {
                    "type": "FeatureCollection",
                    "features": {{ item.fCode.value | raw }}
                }
            });
            {% if 'circle' in item.fCode.value %}
                // Circle layer (based on Point + radius)
                map.addLayer({
                    'id': 'circle-layer-{{ loop.index }}',
                    'type': 'circle',
                    'source': 'polygon-source-{{ loop.index }}',
                    'paint': {
                        'circle-radius': [
                            '*',
                            ['get', 'radius'],  // get the radius from GeoJSON
                            0.1                 // multiply by pixel factor
                        ],
                        'circle-color': ['get', 'color'],
                        'circle-opacity': 0.1,
                        'circle-stroke-color': ['get', 'color'],
                        'circle-stroke-width': 4,
                    }
                });
            {% else %}
                // Fill layer
                map.addLayer({
                    'id': 'polygon-fill-{{ loop.index }}',
                    'type': 'fill',
                    'source': 'polygon-source-{{ loop.index }}',
                    'paint': {
                        'fill-color': ['get', 'color'],   // use color from properties
                        'fill-opacity': 0.4
                    }
                });
                // Outline layer
                map.addLayer({
                    'id': 'polygon-outline-{{ loop.index }}',
                    'type': 'line',
                    'source': 'polygon-source-{{ loop.index }}',
                    'paint': {
                        'line-color': ['get', 'color'],  // same property
                        'line-width': 2
                    }
                });
            {% endif %}
        {% endfor %}
    });
{% endset %}

<div id="map-{{ mapKey }}" class="cellMap"></div>

{# Construct the whole map #}
<script>
    (function() {
        const mapId = 'map-{{ mapKey }}';
        const storageKey = `mapState-${mapId}`;

        // --- Determine initial map state ---
        let initialLat = {{ mapLatitude }};
        let initialLng = {{ mapLongitude }};
        let initialZoom = {{ mapZoom }};

        const savedState = localStorage.getItem(storageKey);
        if (savedState) {
            try {
                const state = JSON.parse(savedState);
                if (typeof state.lat === 'number' && typeof state.lng === 'number' && typeof state.zoom === 'number') {
                    initialLat = state.lat;
                    initialLng = state.lng;
                    initialZoom = state.zoom;
                }
            } catch(e) {
                console.warn(`Failed to parse ${storageKey} from localStorage`, e);
            }
        }

        // --- Initialize the map ---
        const map = new maplibregl.Map({
            container: mapId,
            style: {{ baseMapLayer }},
            center: [initialLng, initialLat],
            zoom: initialZoom,
        });

        {{ mapMarkers }}
        {{ mapDataLayer }}
        {{ polygonLines }}

        // disable scroll zoom
        map.scrollZoom.disable();

        // add zoom controls
        map.addControl(new maplibregl.NavigationControl({
            showZoom: true,
            showCompass: false
        }));

        // --- Save map state on pan/zoom ---
        map.on('moveend', () => {
            const center = map.getCenter();
            const zoom = map.getZoom();

            localStorage.setItem(storageKey, JSON.stringify({
                lng: center.lng,
                lat: center.lat,
                zoom: zoom
            }));
        });
    })();
</script>
