

{# https://maplibre.org/maplibre-gl-js/docs/ #}
{# https://api3.geo.admin.ch/services/sdiservices.html#mapbox-vector-tiles #}
{# Swisstopo Layers: https://wms.geo.admin.ch/?REQUEST=GetCapabilities&SERVICE=WMS&VERSION=1.3.0 #}

<link href="https://unpkg.com/maplibre-gl@5.7.1/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/maplibre-gl@5.7.1/dist/maplibre-gl.js"></script>


{% set mapLatitude = block.fLat ?? '46.798591' %}
{% set mapLongitude = block.fLong ?? '8.231772' %}
{% set mapZoom = block.fZoom ?? '10' %}
{% set mapLayer = block.fPlainTxt %}
{% set polygonPath = block.fCode.value ?? '' %}
{% set markerEnabled = block.fSwitch ?? false %}

{# add markers if they are present #}
    {% set mapMarkers %}
        {% if block.fMxMarker %}
        
            const markers = [
                {% for item in block.fMxMarker %}
                    {
                        coords: [{{ item.fLong }}, {{ item.fLat }}],
                        text: '{{ item.title }}'
                    },
                {% endfor %}  
            ];

            markers.forEach(m => {
                const popup = new maplibregl.Popup({ offset: 25 }).setText(m.text);

                new maplibregl.Marker()
                    .setLngLat(m.coords)
                    .setPopup(popup)
                    .addTo(map);
            });

        {% endif %}
    {% endset %}

{# set base map style #}
{%- set baseMapLayer -%}
    {%- if block.fBaseMap -%}
        {%- switch block.fBaseMap -%}
            {%- case "pixelkarte-farbe" -%}
                'https://vectortiles.geo.admin.ch/styles/ch.swisstopo.basemap.vt/style.json'
            {%- case "swissimage" -%}
                'https://vectortiles.geo.admin.ch/styles/ch.swisstopo.imagerybasemap.vt/style.json'
            {%- case "pixelkarte-grau" -%}
                'https://vectortiles.geo.admin.ch/styles/ch.swisstopo.lightbasemap.vt/style.json'
        {%- endswitch -%}
    {%- endif -%}
{%- endset -%}

{# set additional map data layer #}
{% set mapDataLayer %}
    {% if block.fPlainTxt %}
        map.on('load', () => {
            map.addSource('wms-source', {
                'type': 'raster',
                'tiles': [
                    'https://wms.geo.admin.ch/?SERVICE=WMS&VERSION=1.3.0&REQUEST=GetMap' +
                    '&FORMAT=image/png' +
                    '&TRANSPARENT=true' +
                    '&LAYERS={{ block.fPlainTxt }}' +
                    '&CRS=EPSG:3857' +
                    '&WIDTH=256&HEIGHT=256' +
                    '&BBOX={bbox-epsg-3857}'
                ],
                'tileSize': 256
            });

            map.addLayer({
                'id': 'wms-layer',
                'type': 'raster',
                'source': 'wms-source',
                'paint': {
                    'fill-color': '#888888',   // fill color
                    'fill-opacity': 0.5        // transparency
                }
            });
        });
    {% endif %}
{% endset %}

{# set polygon lines #}
{% set polygonLines %}
    {% if block.fCode.value %}
        map.on('load', () => {
            map.addSource('polygon-source', {
                'type': 'geojson',
                'data': {
                    "type": "FeatureCollection",
                    "features": {{ block.fCode.value | raw }}
                }
            });

            map.addLayer({
                'id': 'polygon-layer',
                'type': 'fill',
                'source': 'polygon-source',
                'layout': {},
                'paint': {
                    'fill-color': '#888888',
                    'fill-opacity': 0.5
                }
            });
        });
    {% endif %}
{% endset %}

<div id="map-{{ block.id }}" class="cellMap"></div>

<script>
    // --- Determine initial map state ---
    let initialLat = {{ mapLatitude }};
    let initialLng = {{ mapLongitude }};
    let initialZoom = {{ mapZoom }};

    const savedState = localStorage.getItem('mapState');
    if (savedState) {
        try {
            const state = JSON.parse(savedState);
            if (state.lat && state.lng && state.zoom) {
                initialLat = state.lat;
                initialLng = state.lng;
                initialZoom = state.zoom;
            }
        } catch(e) {
            console.warn('Failed to parse mapState from localStorage', e);
        }
    }

    // --- Initialize the map ---
    const map = new maplibregl.Map({
        container: 'map-{{ block.id }}',
        style: {{ baseMapLayer }},
        center: [initialLng, initialLat],
        zoom: initialZoom,
    });

    {{ mapMarkers }}
    {{ mapDataLayer }}
    {{ polygonLines }}

    // disable scroll zoom
    map.scrollZoom.disable();

    // add zoom controls
    map.addControl(new maplibregl.NavigationControl({
        showZoom: true,
        showCompass: false
    }));

    // --- Save map state on pan/zoom ---
    map.on('moveend', () => {
        const center = map.getCenter();
        const zoom = map.getZoom();

        localStorage.setItem('mapState', JSON.stringify({
            lng: center.lng,
            lat: center.lat,
            zoom: zoom
        }));
    });
</script>
