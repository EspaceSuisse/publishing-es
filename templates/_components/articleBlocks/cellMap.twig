{# https://maplibre.org/maplibre-gl-js/docs/ #}
{# https://api3.geo.admin.ch/services/sdiservices.html#mapbox-vector-tiles #}
{# Swisstopo Layers: https://wms.geo.admin.ch/?REQUEST=GetCapabilities&SERVICE=WMS&VERSION=1.3.0 #}

<link href="https://unpkg.com/maplibre-gl@5.7.1/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/maplibre-gl@5.7.1/dist/maplibre-gl.js"></script>


{% set mapLatitude = block.fLat %}
{% set mapLongitude = block.fLong %}
{% set mapZoom = block.fZoom ?? '10' %}
{% set additionalLayer = block.fSwisstopoLayer %}
{% set baseLayer = block.fBaseMap ?? 'pixelkarte-farbe' %}
{% set mapID = block.id %}
{% set markerHandle = block.fMxMarker %}
{% set polygonHandle = block.fPolygons %}


{# set base map style #}
{%- set baseMapLayer -%}
    {%- if baseLayer -%}
        {%- switch baseLayer -%}
            {%- case "pixelkarte-farbe" -%}
                'https://vectortiles.geo.admin.ch/styles/ch.swisstopo.basemap.vt/style.json'
            {%- case "swissimage" -%}
                'https://vectortiles.geo.admin.ch/styles/ch.swisstopo.imagerybasemap.vt/style.json'
            {%- case "pixelkarte-grau" -%}
                'https://vectortiles.geo.admin.ch/styles/ch.swisstopo.lightbasemap.vt/style.json'
        {%- endswitch -%}
    {%- endif -%}
{%- endset -%}

{# set additional map data layer #}
{% set mapAdditionalLayer %}
    {% if additionalLayer %}
        map.on('load', () => {
            map.addSource('wms-source', {
                'type': 'raster',
                'tiles': [
                    'https://wms.geo.admin.ch/?SERVICE=WMS&VERSION=1.3.0&REQUEST=GetMap' +
                    '&FORMAT=image/png' +
                    '&TRANSPARENT=true' +
                    '&LAYERS={{ additionalLayer }}' +
                    '&CRS=EPSG:3857' +
                    '&WIDTH=256&HEIGHT=256' +
                    '&BBOX={bbox-epsg-3857}'
                ],
                'tileSize': 256
            });

            map.addLayer({
                'id': 'wms-layer',
                'type': 'raster',
                'source': 'wms-source',
                'paint': {
                    'raster-opacity': 0.5
                }
            });
        });
    {% endif %}
{% endset %}

{# construct markers #}
{% set markerData = [] %}
{% for item in markerHandle %}
    {% set markerData = markerData|merge([{
        lat: item.fLat,
        lng: item.fLong,
        title: item.title
    }]) %}
{% endfor %}


<div id="map-{{ mapID }}" class="cellMap"></div>

{# Construct the whole map #}
<script>
    (function() {
        const mapId = 'map-{{ mapID }}';
        const storageKey = `mapState-${mapId}`;

        // --- Determine initial map state ---
        let initialLat = {{ mapLatitude }};
        let initialLng = {{ mapLongitude }};
        let initialZoom = {{ mapZoom }};

                // Validate coordinates
        if (initialLat < -90 || initialLat > 90) {
            console.warn('Invalid latitude, using default');
            initialLat = 46.798591;
        }
        if (initialLng < -180 || initialLng > 180) {
            console.warn('Invalid longitude, using default');
            initialLng = 8.231772;
        }


        const savedState = localStorage.getItem(storageKey);
        if (savedState) {
            try {
                const state = JSON.parse(savedState);
                if (typeof state.lat === 'number' && typeof state.lng === 'number' && typeof state.zoom === 'number') {
                    initialLat = state.lat;
                    initialLng = state.lng;
                    initialZoom = state.zoom;
                }
            } catch(e) {
                console.warn(`Failed to parse ${storageKey} from localStorage`, e);
            }
        }
        
        
        // --- Initialize the map ---
        const map = new maplibregl.Map({
            container: mapId,
            style: {{ baseMapLayer }},
            center: [initialLng, initialLat],
            zoom: initialZoom,
            glyphs: "https://vectortiles.geo.admin.ch/fonts/{fontstack}/{range}.pbf"
        });

        // disable scroll zoom
        map.scrollZoom.disable();

        // add zoom controls
        map.addControl(new maplibregl.NavigationControl({
            showZoom: true,
            showCompass: false,
            showFullscreen: true
        }));

        map.addControl(new maplibregl.FullscreenControl(), 'top-right');

        // ADDITIONAL SWISSTOPO LAYER
        {{ mapAdditionalLayer|raw }}

        //makrers
        map.on('load', () => {
            const markers = {{ markerData | json_encode() | raw }};
            const features = markers.map(m => ({
                type: 'Feature',
                geometry: { type: 'Point', coordinates: [m.lng, m.lat] },
                properties: { title: m.title }
            }));

            // GeoJSON source for marker labels
            map.addSource('marker-labels', {
                type: 'geojson',
                data: {
                    type: 'FeatureCollection',
                    features: features
                }
            });

            // Add symbol layer at the **very top** to ensure visibility
            map.addLayer({
                id: 'marker-labels-layer',
                type: 'symbol',
                source: 'marker-labels',
                layout: {
                    'text-field': ['get', 'title'],
                    'text-font': ['Frutiger Neue Italic'],
                    'text-size': 14,
                    'text-offset': [0, 1.5],
                    'text-anchor': 'top'
                },
                paint: {
                    'text-color': '#000000',
                    'text-halo-color': '#ffffff',
                    'text-halo-width': 1
                }
            }, map.getStyle().layers[map.getStyle().layers.length - 1].id); // force top

            // Optional: add actual red dots
            markers.forEach(m => {
                new maplibregl.Marker()
                    .setLngLat([m.lng, m.lat])
                    .addTo(map);
            });
        });

        // construct and display poligon fields
        map.on('load', () => {
            map.addSource('polygons', {
                type: 'geojson',
                data: {
                type: 'FeatureCollection',
                features: [
                    {% for item in polygonHandle %}
                    {% set code = item.fCode|trim %}
                    {% if code starts with '[' and code ends with ']' %}
                        {{- code|slice(1, code|length - 2)|raw -}}
                    {% else %}
                        {{- code|raw -}}
                    {% endif %},
                    {% endfor %}
                ]
                }
            });

            map.addLayer({
                id: 'polygon-fills',
                type: 'fill',
                source: 'polygons',
                filter: ['any', ['==', ['geometry-type'], 'Polygon'], ['==', ['geometry-type'], 'MultiPolygon']],
                paint: { 'fill-color': ['coalesce', ['get', 'color'], '#f0c96a'], 'fill-opacity': 0.5 }
            });

            map.addLayer({
                id: 'polygon-borders',
                type: 'line',
                source: 'polygons',
                filter: ['any', ['==', ['geometry-type'], 'Polygon'], ['==', ['geometry-type'], 'MultiPolygon']],
                paint: { 'line-color': ['coalesce', ['get', 'color'], '#f0c96a'], 'line-width': 2 }
            });

            // Circles (simple: radius interpreted as pixels)
            map.addLayer({
            id: 'circle-fills',
            type: 'circle',
            source: 'polygons',
            filter: ['all',
                ['==', ['geometry-type'], 'Point'],
                ['==', ['get', 'type'], 'circle']
            ],
            paint: {
                // color with fallback in case your HSL string isn't parsed
                'circle-color': ['coalesce', ['get', 'color'], '#39d98a'],
                'circle-opacity': 0.35,
                // radius in PIXELS from your feature's "radius" property
                'circle-radius': ['coalesce', ['get', 'radius'], 10],
                // optional stroke
                'circle-stroke-color': ['coalesce', ['get', 'color'], '#39d98a'],
                'circle-stroke-width': 2
            }
            });
        });

        // --- Save map state on pan/zoom ---
        map.on('moveend', () => {
            const center = map.getCenter();
            const zoom = map.getZoom();

            localStorage.setItem(storageKey, JSON.stringify({
                lng: center.lng,
                lat: center.lat,
                zoom: zoom
            }));
        });
    })();
</script>
