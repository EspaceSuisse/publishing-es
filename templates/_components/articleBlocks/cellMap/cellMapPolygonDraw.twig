// --- Polygon Section ---
  const rawPolygonPath = {{ polygonPath|json_encode|raw }};
  if (rawPolygonPath.trim() !== '') {
    const coordsWGS84 = rawPolygonPath
      .trim()
      .split(/\r?\n/)
      .map(line => line.trim().split(',').map(Number));
    const coords3857 = coordsWGS84.map(coord => fromLonLat(coord));

    const polygon = new Polygon([coords3857]);
    const polygonFeature = new Feature(polygon);
    polygonFeature.setStyle(new Style({
      stroke: new Stroke({ color: '#0074D9', width: 2 }),
      fill: new Fill({ color: 'rgba(0, 116, 217, 0.1)' })
    }));

    const vectorLayer = new VectorLayer({
      source: new VectorSource({ features: [polygonFeature] })
    });
    map.addLayer(vectorLayer);
  }

  