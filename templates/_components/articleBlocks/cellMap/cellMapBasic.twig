// Register EPSG:2056 projection
  proj4.defs("EPSG:2056", "+proj=somerc +lat_0=46.95240555555556 +lon_0=7.439583333333333 +k_0=1 +x_0=2600000 +y_0=1200000 +ellps=bessel +units=m +no_defs");
  register(proj4);

  // Create a Swisstopo tile layer
    const swisstopoLayer = new TileLayer({
        source: new XYZ({
            // URL template for Swiss topo tiles:
            url: 'https://wmts.geo.admin.ch/1.0.0/ch.swisstopo.{{ block.fBaseMap }}/default/current/3857/{z}/{x}/{y}.jpeg',
            // You can also try other layers, e.g. pixelkarte-grau, pixelkarte-farbe
            maxZoom: 18,
        })
    });

  const swissCoordinates = [{{ mapLatitude }}, {{ mapLongitude }}];
  const markerEnabled = {{ markerEnabled ? 'true' : 'false' }};

  const map = new Map({
    target: 'map-{{ block.id }}',
    layers: [swisstopoLayer],
    view: new View({
      center: fromLonLat([0, 0]),
      zoom: {{ mapZoom }},
    }),
    interactions: defaultInteractions({ mouseWheelZoom: false })
  });

  const transformedCoordinates = transform(
    swissCoordinates,
    'EPSG:2056',
    'EPSG:3857'
  );
  map.getView().setCenter(transformedCoordinates);