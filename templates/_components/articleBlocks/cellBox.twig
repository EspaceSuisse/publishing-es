{# This is the Article Element of the box in all articles #}

{% set expanded = block.fSwitch %}
{% set expandedClass = expanded ? 'expanded' : 'collapsed' %}

<div class="boxHead">

    
    {% if expandedClass == 'collapsed' %}
        <button 
            class="cellBoxToggle {% if expandedClass == 'collapsed' %}closed{% else %}open{% endif %}"
            aria-expanded="{{ expanded ? 'true' : 'false' }}"
            aria-controls="cellBoxContent-{{ block.id }}">

            <h3 class="cellCardTitle" id="cellBoxTitle-{{ block.id }}">{{ block.title }}</h3>

        </button>
    {% else %}

        <h3 class="cellCardTitle nonCollapsable" id="cellBoxTitle-{{ block.id }}">{{ block.title }}</h3>

    {% endif %}
</div>

<div class="cellBoxContent {{ expandedClass }}" id="cellBoxContent-{{ block.id }}" role="region" aria-labelledby="cellBoxTitle-{{ block.id }}">
    <div class="cellBoxInner">{{ block.fRichTextI18n }}</div>
</div>

{% js %}
    document.addEventListener("click", (e) => {
    if (e.target.matches(".cellBoxToggle")) {
        const btn = e.target;
        const content = document.getElementById(btn.getAttribute("aria-controls")); // <-- use aria-controls

        if (content.classList.contains("expanded")) {
            // collapse
            content.style.height = content.scrollHeight + "px";
            content.offsetHeight; // force reflow
            content.style.height = "0px";
            content.classList.remove("expanded");
            btn.classList.remove("open");
            btn.classList.add("closed");
        } else {
            // expand
            content.style.height = content.scrollHeight + "px";
            content.classList.add("expanded");
            btn.classList.remove("closed");
            btn.classList.add("open");

            content.addEventListener("transitionend", function handler() {
                content.style.height = "auto"; // reset to auto
                content.removeEventListener("transitionend", handler);
            });
        }
    }
});


{% endjs %}
