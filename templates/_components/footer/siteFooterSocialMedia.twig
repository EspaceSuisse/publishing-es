{# Grabs the data from the seomaticPlugin site settings social media in seomatic #}
{% set esSocialMedia = seomatic.site.sameAsLinks %}

<ul>
	{% for item in esSocialMedia %}
		<li><a href="{{ item.url }}">{{ item.siteName }}</a></li>
	{% endfor %}
	<li><a href="{{ siteUrl ~ 'feeds/articles-' ~ craft.app.language |slice(0,2) }}.rss">RSS ({{ craft.app.language }})</a></li>
</ul>