
{% import '_macros/macroPostDate' as macroPostDate %}



{% set smallerGrid = 'gridStart2 gridSpan10' %}



<header class="newsHeadCard gridArticle headerSection{{ entry.section.handle | capitalize }}">
	<div class="gridStart2 gridSpan11 newsCardHead">
		{{ macroPostDate.postDate(entry) }}
		{% include "_components/articleShare" %}
	</div>
	<h1 class="{{ smallerGrid }} newsTitle">{{ entry.title }}</h1>
	{# Lead Text #}
	<p class="{{ smallerGrid }} newsLeadText">{{ entry.fSeoDescription }}</p>
	<div class="headMeta {{ smallerGrid }}">
		{% include "_components/listingAuthors" %}
	</div>
	
	<span class="articleId">ID: {{ entry.id }}</span>
</header>
