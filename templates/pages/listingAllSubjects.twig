{% extends "_layouts/main" %}

{% import '_components/previewCards/macroPreviewNews' as macroPreviewNews %}

{% block content %}

	{% set allItems = craft.categories()
		.group('catSubject')
		.limit(null)
		.all()
	%}


	

	<header class="pageHead subPageHead">
		{% include "_components/header/headerBrand" %}
		{% include "_components/header/headerPage" %}
	</header>


	<div class="listingGrid">
		<ul>
			{% for item in allItems %}
				{% set hasEntries = craft.entries()
					.relatedTo(item)
					.exists()
				%}
				{% if hasEntries %}
					<li><a href="{{ item.url }}">{{ item.title }}</a></li>
				{% endif %}
			{% endfor %}
		</ul>
	</div>

{% endblock %}
