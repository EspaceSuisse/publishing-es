{% extends "_layouts/main" %}

{% import '_components/previewCards/macroPreviewArticle' as macroPreview %}
{% import '_macros/macroCatOverview' as macroCat %}

{% block content %}

	{% set catGenre = craft.categories()
		.group('catGenre')
		.relatedTo({ sourceElement: craft.entries.section('article').ids() })
		.all()
	%}

	{% set catSubject = craft.categories()
		.group('catSubject')
		.relatedTo({ sourceElement: craft.entries.section('article').ids() })
		.all()
	%}

	{% set allEntries = craft.entries()
		.section('article')
		.with(['fCatGenre', 'fCatSubject'])
		.limit(null)
		.all()
	%}

	{% set newsEntries = craft.entries.section('news').limit(3).all() %}
	{% set goToAllNews = craft.entries.section('listingNews').with(['title','url']).one() %}

	<div class="listingGrid listingSection">
		{% include "_components/header/headerBrand" %}
		
		{% for item in allEntries | slice(0,1) %}
			{{ macroPreview.listMacro(item,'gridSpan12',' gridSpan12 gridMdSpan6','gridSpan12 gridMdSpan6') }}
		{% endfor %}
		{% for item in allEntries | slice(1,2) %}
				{{ macroPreview.listMacro(item,'gridSpan12 gridMdSpan6','gridSpan12','gridSpan12') }}
		{% endfor %}
	</div>
		{% include "_components/indexNewsTeaser.twig" %}
		{% include "_components/listingSuperTopic" %}
		{% include "_components/listingCatList" %}
	<div class="listingGrid listingSection">
		{% for item in allEntries | slice(4,4) %}
			{{ macroPreview.listMacro(item,'gridSpan12','gridSpan12 gridMdSpan4','gridSpan12 gridMdSpan8') }}
		{% endfor %}
	</div>
	<div class="listingGrid listingSection">
		{% for item in allEntries | slice(8) %}
			{{ macroPreview.listMacro(item,'gridSpan6','gridSpan12 gridMdSpan12','gridSpan12 gridMdSpan12') }}
		{% endfor %}
	</div>

	
{% endblock %}
